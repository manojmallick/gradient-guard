# ── DigitalOcean Core ──────────────────────────────────────────
DIGITALOCEAN_API_TOKEN=dop_v1_xxxx          # DO personal access token (all CRUD scopes)
DO_REGION=ams3                              # Amsterdam — EU data residency (required for DORA/GDPR)

# ── Gradient AI Platform ───────────────────────────────────────
GRADIENT_MODEL_ACCESS_KEY=xxxx              # From: Gradient > Serverless Inference > Model Access Keys

# ── Gradient Agent Endpoints (set AFTER `gradient agent deploy`) ──
GRADIENT_AGENT_KEY_SENTINEL=xxxx
GRADIENT_AGENT_URL_SENTINEL=https://dora-sentinel.agents.do-ai.run
GRADIENT_AGENT_KEY_EVIDENCE=xxxx
GRADIENT_AGENT_URL_EVIDENCE=https://evidence-forge.agents.do-ai.run
GRADIENT_AGENT_KEY_REMEDIATION=xxxx
GRADIENT_AGENT_URL_REMEDIATION=https://remediation-advisor.agents.do-ai.run
GRADIENT_AGENT_KEY_COUNSEL=xxxx
GRADIENT_AGENT_URL_COUNSEL=https://compliance-counsel.agents.do-ai.run

# ── Knowledge Base IDs (set AFTER KB creation) ─────────────────
GRADIENT_KB_DORA_ID=xxxx
GRADIENT_KB_NIS2_ID=xxxx
GRADIENT_KB_GDPR_ID=xxxx
GRADIENT_KB_MAS_ID=xxxx
GRADIENT_KB_INCIDENTS_ID=xxxx               # Internal: past incidents + runbooks

# ── DO Managed PostgreSQL ──────────────────────────────────────
DATABASE_URL=postgresql://doadmin:xxxx@db-postgresql-ams3-xxxx.db.ondigitalocean.com:25060/gradientguard?sslmode=require

# ── DO Spaces ─────────────────────────────────────────────────
DO_SPACES_KEY=xxxx
DO_SPACES_SECRET=xxxx
DO_SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com
DO_SPACES_BUCKET=gradient-guard-evidence
DO_SPACES_CDN_ENDPOINT=https://gradient-guard-evidence.ams3.cdn.digitaloceanspaces.com

# ── App Config ────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001
NEXT_PUBLIC_API_URL=https://gradient-guard-api.ondigitalocean.app
NEXT_PUBLIC_APP_URL=https://gradient-guard.ondigitalocean.app

# ── Optional Integrations ─────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxx   # For A3 notifications
